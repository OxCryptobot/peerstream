{
  "name": "PayTray Backend",
  "description": "Production-grade fintech backend with decentralized profiles and payment streams",
  "keywords": ["node", "express", "blockchain", "sablier", "ceramic", "web3"],
  "repository": "https://github.com/yourusername/peerstream",
  "success_url": "/health",
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "JWT_SECRET": {
      "description": "JWT secret key (minimum 32 characters)",
      "generator": "secret",
      "required": true
    },
    "WEB3_SIGNATURE_SALT": {
      "description": "Web3 signature verification salt",
      "generator": "secret",
      "required": true
    },
    "DATABASE_URL": {
      "description": "PostgreSQL database URL",
      "required": true
    },
    "LIVEKIT_API_KEY": {
      "description": "LiveKit API key for video conferencing",
      "required": true
    },
    "LIVEKIT_API_SECRET": {
      "description": "LiveKit API secret",
      "required": true
    },
    "LIVEKIT_URL": {
      "description": "LiveKit server URL",
      "required": true
    },
    "CERAMIC_URL": {
      "description": "Ceramic network URL",
      "value": "https://mainnet.ceramic.network"
    },
    "ETHEREUM_RPC_URL": {
      "description": "Ethereum mainnet RPC URL (use Alchemy, Infura, or similar)",
      "required": true
    },
    "ARBITRUM_RPC_URL": {
      "description": "Arbitrum One RPC URL",
      "required": true
    },
    "OPTIMISM_RPC_URL": {
      "description": "Optimism RPC URL",
      "required": true
    },
    "SENTRY_DSN": {
      "description": "Sentry error tracking DSN (optional)",
      "required": false
    },
    "SENDGRID_API_KEY": {
      "description": "SendGrid API key for emails (optional)",
      "required": false
    },
    "LOG_LEVEL": {
      "description": "Logging level",
      "value": "info"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:standard-0",
      "options": {
        "version": "14"
      }
    }
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "standard-1x"
    },
    "worker": {
      "quantity": 1,
      "size": "standard-1x"
    }
  },
  "stack": "heroku-22"
}
