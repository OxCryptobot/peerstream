{
  "$schema": "https://railway.app/schemas/v1",
  "projectName": "paytray-backend",
  "services": [
    {
      "name": "backend",
      "builder": "dockerfile",
      "dockerfilePath": "Dockerfile",
      "rootDirectory": ".",
      "port": 3001,
      "variables": {
        "NODE_ENV": "production",
        "REDIS_ENABLED": "false",
        "CERAMIC_ENABLED": "false",
        "LIVEKIT_ENABLED": "false",
        "SABLIER_ENABLED": "false"
      }
    }
  ]
}
