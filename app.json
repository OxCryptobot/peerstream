{
  "name": "PayTray - Web3 Payment Streaming Platform",
  "description": "Peer-to-peer payment streaming on blockchain with video calls and decentralized profiles",
  "repository": "https://github.com/yourusername/peerstream",
  "keywords": [
    "web3",
    "blockchain",
    "payment-streaming",
    "ethereum",
    "livekit",
    "ceramic",
    "sablier"
  ],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Environment (production, staging, development)",
      "value": "production",
      "required": true
    },
    "DATABASE_URL": {
      "description": "PostgreSQL database connection string",
      "required": true
    },
    "REDIS_URL": {
      "description": "Redis connection URL for distributed rate limiting and caching",
      "required": true
    },
    "REDIS_ENABLED": {
      "description": "Enable Redis for distributed features",
      "value": "true",
      "required": true
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token generation",
      "generator": "secret",
      "required": true
    },
    "JWT_REFRESH_SECRET": {
      "description": "Secret key for JWT refresh token generation",
      "generator": "secret",
      "required": true
    },
    "JWT_EXPIRATION": {
      "description": "JWT token expiration in seconds",
      "value": "900",
      "required": false
    },
    "JWT_REFRESH_EXPIRATION": {
      "description": "JWT refresh token expiration in seconds",
      "value": "604800",
      "required": false
    },
    "CORS_ORIGIN": {
      "description": "CORS origin whitelist (comma-separated)",
      "value": "http://localhost:3000,http://localhost:5173,https://paytray.io",
      "required": true
    },
    "CERAMIC_ENABLED": {
      "description": "Enable Ceramic Network for decentralized profiles",
      "value": "true",
      "required": false
    },
    "CERAMIC_NODE_URL": {
      "description": "Ceramic node URL",
      "value": "https://ceramic.example.com",
      "required": false
    },
    "SABLIER_ENABLED": {
      "description": "Enable Sablier for payment streaming",
      "value": "true",
      "required": false
    },
    "ETHEREUM_RPC_URL": {
      "description": "Ethereum mainnet RPC endpoint",
      "required": true
    },
    "SEPOLIA_RPC_URL": {
      "description": "Ethereum Sepolia testnet RPC endpoint",
      "required": false
    },
    "ARBITRUM_RPC_URL": {
      "description": "Arbitrum One RPC endpoint",
      "required": false
    },
    "OPTIMISM_RPC_URL": {
      "description": "Optimism RPC endpoint",
      "required": false
    },
    "LIVEKIT_API_KEY": {
      "description": "LiveKit API key for video streaming",
      "required": true
    },
    "LIVEKIT_API_SECRET": {
      "description": "LiveKit API secret for video streaming",
      "required": true
    },
    "LIVEKIT_API_URL": {
      "description": "LiveKit server URL",
      "required": true
    },
    "USDC_ADDRESS": {
      "description": "USDC token contract address (Ethereum mainnet)",
      "value": "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48",
      "required": false
    },
    "USDT_ADDRESS": {
      "description": "USDT token contract address (Ethereum mainnet)",
      "value": "0xdac17f958d2ee523a2206206994597c13d831ec7",
      "required": false
    },
    "DAI_ADDRESS": {
      "description": "DAI token contract address (Ethereum mainnet)",
      "value": "0x6B175474E89094C44Da98b954EedeAC495271d0F",
      "required": false
    },
    "SABLIER_ADDRESS": {
      "description": "Sablier V2 contract address (Ethereum mainnet)",
      "required": false
    },
    "RATE_LIMIT_WINDOW_MS": {
      "description": "Rate limit window in milliseconds",
      "value": "60000",
      "required": false
    },
    "RATE_LIMIT_MAX_REQUESTS": {
      "description": "Maximum requests per window",
      "value": "100",
      "required": false
    },
    "DB_POOL_MIN": {
      "description": "Minimum database connection pool size",
      "value": "5",
      "required": false
    },
    "DB_POOL_MAX": {
      "description": "Maximum database connection pool size",
      "value": "20",
      "required": false
    },
    "LOG_LEVEL": {
      "description": "Logging level (ERROR, WARN, INFO, DEBUG)",
      "value": "INFO",
      "required": false
    },
    "SENTRY_DSN": {
      "description": "Sentry error tracking DSN",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 2,
      "size": "standard-1x"
    },
    "worker": {
      "quantity": 1,
      "size": "standard-1x"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:standard-0",
      "as": "DATABASE"
    },
    {
      "plan": "heroku-redis:premium-0",
      "as": "REDIS"
    }
  ],
  "scripts": {
    "postdeploy": "npm run migrate"
  }
}
