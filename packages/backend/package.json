{
  "name": "@paytray/backend",
  "version": "1.0.0",
  "description": "PayTray Backend Server - LiveKit, Wallet Verification, and Payment Streaming",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node workers/index.js",
    "worker:dev": "nodemon workers/index.js",
    "db:init": "node scripts/db-init.js",
    "db:init:seed": "node scripts/db-init.js --seed",
    "db:migrate": "node scripts/db-init.js",
    "db:reset": "node scripts/db-reset.js",
    "migrate": "node migrations/run.js",
    "migrate:status": "node migrations/run.js --status",
    "seed": "node scripts/seed.js",
    "setup": "npm run db:init && npm run seed",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "npm run lint && npm run test",
    "queue:health": "node -e \"import('./lib/messageQueue.js').then(m => m.getQueueManager().getAllStats()).then(s => console.log(JSON.stringify(s, null, 2)))\"",
    "heroku-postbuild": "npm run db:migrate"
  },
  "dependencies": {
    "bull": "^4.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "6.10.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "livekit-server-sdk": "^0.5.2",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "paytray",
    "livekit",
    "web3",
    "ethereum",
    "wallet",
    "streaming"
  ],
  "author": "PayTray Team",
  "license": "MIT"
}
